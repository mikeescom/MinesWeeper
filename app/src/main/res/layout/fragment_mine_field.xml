<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/FFEAA6"
    tools:context=".view.fragment.MineFieldFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="7dp">
        <LinearLayout
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:gravity="center"
            android:layout_marginEnd="10dp">
            <androidx.cardview.widget.CardView
                android:id="@+id/profile_image_card_view"
                android:layout_width="50dp"
                android:layout_height="50dp"
                app:cardCornerRadius="7dp">
                <ImageView
                    android:id="@+id/profile_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
        <TextView
            android:id="@+id/profile_name"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="4"
            android:gravity="center"
            android:fontFamily="@font/game_played"
            android:textColor="@color/digital_color_bg"
            android:textSize="18sp"
            android:lines="2"
            tools:text="Miguel Saavedra Lozano"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/information_layout"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="6dp"
        android:background="@color/FFEAA6">
        <!--COUNTER-->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="start"
            android:orientation="horizontal"
            android:background="@color/FFEAA6">
            <ImageView
                android:id="@+id/counter_tens"
                android:layout_width="40dp"
                android:layout_height="49dp"
                app:layout_constraintStart_toEndOf="@+id/counter_hundreds"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:src="@drawable/digit_0" />
            <ImageView
                android:id="@+id/counter_units"
                android:layout_width="40dp"
                android:layout_height="49dp"
                app:layout_constraintStart_toEndOf="@+id/counter_tens"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:src="@drawable/digit_0" />
        </LinearLayout>
        <ImageView
            android:id="@+id/new_icon"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:layout_marginStart="10dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:src="@drawable/ic_new"/>
        <ImageView
            android:id="@+id/pause_icon"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="10dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:src="@drawable/ic_pause"/>
        <!--TIMER-->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="end"
            android:background="@color/FFEAA6">
            <ImageView
                android:id="@+id/tens_minutes"
                android:layout_width="40dp"
                android:layout_height="49dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:src="@drawable/digit_0"/>
            <ImageView
                android:id="@+id/units_minutes"
                android:layout_width="40dp"
                android:layout_height="49dp"
                app:layout_constraintStart_toEndOf="@+id/tens_minutes"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:src="@drawable/digit_0"/>
            <ImageView
                android:id="@+id/clock_divider"
                android:layout_width="5dp"
                android:layout_height="49dp"
                app:layout_constraintStart_toEndOf="@+id/units_minutes"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:src="@drawable/digit_0"/>
            <ImageView
                android:id="@+id/tens_seconds"
                android:layout_width="40dp"
                android:layout_height="49dp"
                app:layout_constraintStart_toEndOf="@+id/clock_divider"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:src="@drawable/digit_0" />
            <ImageView
                android:id="@+id/units_seconds"
                android:layout_width="40dp"
                android:layout_height="49dp"
                app:layout_constraintStart_toEndOf="@+id/tens_seconds"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:src="@drawable/digit_0" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="vertical">
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <GridLayout
                android:id="@+id/mine_field"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="5dp"/>
        </HorizontalScrollView>
    </ScrollView>
</LinearLayout>